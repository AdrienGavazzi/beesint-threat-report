# NVD API — nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# ThreatFox (abuse.ch) — optionnel (lot 7). Sans clé, l'étape est sautée proprement
# (dégradation propre, aucun crash). Inscription : auth.abuse.ch
THREATFOX_AUTH_KEY=

# GreyNoise Community API — optionnel. Sans clé, l'étape est sautée proprement
# (dégradation propre, aucun crash). Inscription : greynoise.io
GREYNOISE_API_KEY=

# BreachDirectory via RapidAPI — optionnel (cross-check secondaire des breaches, en plus de
# HaveIBeenPwned). Sans clé, dégradation propre (compte à 0, aucun crash). Inscription :
# rapidapi.com/rohan-patra/api/breachdirectory
RAPIDAPI_KEY=

# OpenPhish — flux public gratuit, aucune clé requise (remplace PhishTank, dont les
# inscriptions sont fermées). URL par défaut posée dans config.py, pas de variable d'env ici.

# Oracle Object Storage — Customer Secret Key (voir étape 6)
ORACLE_S3_ACCESS_KEY=
ORACLE_S3_SECRET_KEY=
ORACLE_S3_ENDPOINT=
ORACLE_S3_BUCKET=

# Secret partagé webhook ETL -> beesint-backend (POST /internal/threat-report/status)
THREAT_REPORT_INTERNAL_SECRET=

# Sentry — projet dédié "beesint-threat-report" (séparé du Sentry backend)
SENTRY_DSN_THREAT_REPORT=

# Stockage : "local" (défaut, dev) | "s3" (nécessite les 4 vars ORACLE_S3_* ci-dessus)
STORAGE_BACKEND=local

# URL du webhook interne beesint-backend (dry-run/log seul si absent — Lot 6 pas encore là)
BACKEND_WEBHOOK_URL=

# Fenêtre de rapport et caps volumétriques (défauts raisonnables, rarement à changer)
REPORT_WINDOW_DAYS=7
MAX_RESULTS_NVD=2000
MAX_RESULTS_KEV=5000

# Tag environnement Sentry
ENVIRONMENT=development
