<section class="section">
  <h2 class="section-title">Active C2 Infrastructure</h2>
  <p class="section-desc">Command-and-control servers currently online — the machines malware "phones home" to for instructions and stolen data.</p>
  <div class="kpi-grid">
    <div class="kpi-card">
      <div class="value">{{ c2.active_count }}</div>
      <div class="label">Active C2 IPs</div>
      {% if c2.sparkline %}<div class="kpi-spark">{{ c2.sparkline | safe }}</div>{% endif %}
    </div>
    <div class="kpi-card">
      <div class="value">
        {% if c2.trend_pct is none %}
          N/A
        {% elif c2.trend_pct >= 0 %}
          <span class="trend-up">+{{ c2.trend_pct }}%</span>
        {% else %}
          <span class="trend-down">{{ c2.trend_pct }}%</span>
        {% endif %}
      </div>
      <div class="label">Trend vs previous run</div>
    </div>
    {% if c2.cross_confirmed %}
    <div class="kpi-card">
      <div class="value">{{ c2.cross_confirmed.confirmed }}/{{ c2.cross_confirmed.total }}</div>
      <div class="label">Cross-confirmed (2+ feeds)</div>
    </div>
    {% endif %}
  </div>

  {% if c2.map_svg %}
  <div class="map-frame">
    {{ c2.map_svg | safe }}
  </div>
  {% endif %}

  {% if c2['items'] %}
  <table class="c2-table">
    <thead>
      <tr>
        <th class="mono">IP address</th>
        <th>Country</th>
        <th>ASN</th>
        <th>Malware family</th>
        <th>First seen</th>
        <th>Last online</th>
        <th>Signals</th>
      </tr>
    </thead>
    <tbody>
      {% for item in c2['items'] %}
      <tr>
        <td class="mono">{{ item.ip_address }}</td>
        <td>{{ item.country if item.country else "N/A" }}</td>
        <td class="mono">{{ item.asn if item.asn else "N/A" }}</td>
        <td>{{ item.malware_family if item.malware_family else "N/A" }}</td>
        <td>{{ item.first_seen | fmt_date_short if item.first_seen else "N/A" }}</td>
        <td>{{ item.last_online | fmt_date_short if item.last_online else "N/A" }}</td>
        <td>
          <span class="source-dot {{ 'source-dot-ok' if item.confirmed_by_spamhaus else 'source-dot-off' }}" title="Spamhaus DROP/EDROP"></span>
          {% if item.greynoise_classification %}<span class="badge {{ 'badge-error' if item.greynoise_classification == 'malicious' else 'badge-neutral' }}">{{ item.greynoise_classification }}</span>{% else %}<span class="badge badge-neutral">N/A</span>{% endif %}
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% endif %}

  {% if c2.malware_family_breakdown %}
  <p class="chart-card-title" style="margin-top: 12px;">Malware family breakdown</p>
  {% if c2.malware_family_chart %}
  {{ c2.malware_family_chart | safe }}
  {% else %}
  <div class="chip-list">
    {% for item in c2.malware_family_breakdown %}<span class="chip{{ ' chip-lead' if loop.first }}">{{ item.malware_family }}<span class="chip-count">{{ item.count }}</span></span>{% endfor %}
  </div>
  {% endif %}
  {% endif %}

  {% if c2.top_asn %}
  <p class="chart-card-title" style="margin-top: 12px;">Top ASN / hosting</p>
  {% if c2.top_asn_chart %}
  {{ c2.top_asn_chart | safe }}
  {% else %}
  <div class="chip-list">
    {% for item in c2.top_asn %}<span class="chip{{ ' chip-lead' if loop.first }}">{{ item.asn }}<span class="chip-count">{{ item.count }}</span></span>{% endfor %}
  </div>
  {% endif %}
  {% endif %}

  {% if c2.open_ports_breakdown %}
  <p class="chart-card-title" style="margin-top: 12px;">Top open ports (Shodan InternetDB)</p>
  {% if c2.open_ports_chart %}
  {{ c2.open_ports_chart | safe }}
  {% else %}
  <div class="chip-list">
    {% for item in c2.open_ports_breakdown %}<span class="chip{{ ' chip-lead' if loop.first }}">{{ item.port }}<span class="chip-count">{{ item.count }}</span></span>{% endfor %}
  </div>
  {% endif %}
  {% endif %}
</section>
