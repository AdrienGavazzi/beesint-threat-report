<section class="section">
  <h2 class="section-title">Top 10 Countries - C2 Infrastructure</h2>
  <p class="section-desc">Where the active C2 servers above are physically hosted, by country.</p>
  {% if geo.top_countries %}
  <div class="chip-list">
    {% for item in geo.top_countries %}<span class="chip{{ ' chip-lead' if loop.first }}">{{ item.country_name }} ({{ item.country_code }})<span class="chip-count">{{ item.count }}</span></span>{% endfor %}
  </div>
  {% endif %}
</section>
