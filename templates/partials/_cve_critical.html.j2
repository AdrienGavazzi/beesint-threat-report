{% from "macros.html.j2" import source_link %}
<section class="section" id="sec-cve-critical">
  <h2 class="section-title">New Critical CVEs</h2>
  <p class="section-desc">Newly disclosed vulnerabilities rated 9.0+ severity — the ones attackers move fastest to weaponize.</p>
  <div class="kpi-grid">
    <div class="kpi-card">
      <div class="value">{{ cve.critical_count }}</div>
      <div class="label">Critical this week</div>
      {% if cve.sparkline %}<div class="kpi-spark">{{ cve.sparkline | safe }}</div>{% endif %}
    </div>
    <div class="kpi-card">
      <div class="value">
        {% if cve.critical_trend_pct is none %}
          N/A
        {% elif cve.critical_trend_pct >= 0 %}
          <span class="trend-up">+{{ cve.critical_trend_pct }}%</span>
        {% else %}
          <span class="trend-down">{{ cve.critical_trend_pct }}%</span>
        {% endif %}
      </div>
      <div class="label">Trend vs previous run</div>
    </div>
    <div class="kpi-card">
      <div class="value">{{ cve.high_volume_count }}</div>
      <div class="label">High severity volume</div>
    </div>
  </div>

  {% if cve.severity_donut or cve.cvss_histogram or cve.cvss_epss_scatter %}
  <div class="chart-row">
    {% if cve.severity_donut %}
    <div class="chart-card">
      <p class="chart-card-title">Severity split</p>
      <div class="donut-row">
        {{ cve.severity_donut | safe }}
        <div class="chart-legend">
          <span class="chart-legend-item"><span class="chart-legend-dot" style="background:#EF4444"></span>Critical<span class="chip-count">{{ cve.critical_count }}</span></span>
          <span class="chart-legend-item"><span class="chart-legend-dot" style="background:#F59E0B"></span>High<span class="chip-count">{{ cve.high_volume_count }}</span></span>
        </div>
      </div>
    </div>
    {% endif %}
    {% if cve.cvss_histogram %}
    <div class="chart-card">
      <p class="chart-card-title">CVSS score distribution (critical CVEs)</p>
      {{ cve.cvss_histogram | safe }}
    </div>
    {% endif %}
    {% if cve.cvss_epss_scatter %}
    <div class="chart-card">
      <p class="chart-card-title">CVSS &times; EPSS — real exploitation priority</p>
      {{ cve.cvss_epss_scatter | safe }}
      <p class="section-desc" style="margin-top: 6px; font-size: 9px;">{{ cve.cvss_epss_subtitle }} Color: <span style="color:#22C55E;">green</span> &lt;0.1, <span style="color:#F59E0B;">amber</span> 0.1-0.5, <span style="color:#EF4444;">red</span> &gt;0.5 EPSS.</p>
    </div>
    {% endif %}
  </div>
  {% endif %}

  {% if cve.critical_items %}
  <table>
    <thead>
      <tr>
        <th class="mono">CVE</th>
        <th>Description</th>
        <th>CVSS</th>
        <th>EPSS</th>
        <th>Published</th>
        <th>Vendor</th>
        <th>Link</th>
      </tr>
    </thead>
    <tbody>
      {% for item in cve.critical_items %}
      <tr>
        <td class="mono">{{ item.cve_id }}</td>
        <td>{{ item.description }}</td>
        <td class="mono">{{ item.cvss_score if item.cvss_score is not none else "N/A" }}</td>
        <td>
          {% if item.epss_score is not none %}
            {% if item.epss_score > 0.5 %}<span class="badge badge-error">{{ "%.2f"|format(item.epss_score) }}</span>
            {% elif item.epss_score > 0.1 %}<span class="badge badge-warning">{{ "%.2f"|format(item.epss_score) }}</span>
            {% else %}<span class="badge badge-success">{{ "%.2f"|format(item.epss_score) }}</span>{% endif %}
          {% else %}<span class="mono" style="color: var(--color-text-muted);">N/A</span>{% endif %}
        </td>
        <td>{{ item.published_date | fmt_date_short }}</td>
        <td>{{ item.vendor if item.vendor else "N/A" }}</td>
        <td>{{ source_link("https://nvd.nist.gov/vuln/detail/" ~ item.cve_id, "NVD") }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% endif %}
</section>
