{% from "macros.html.j2" import source_link %}
<section class="section" id="sec-malicious-urls">
  <h2 class="section-title">Malicious URLs Online</h2>
  <p class="section-desc">Live links currently hosting malware or phishing pages — still reachable by a victim clicking today.</p>
  <div class="kpi-grid">
    <div class="kpi-card">
      <div class="value">{{ malicious_urls.online_count }}</div>
      <div class="label">Online now</div>
      {% if malicious_urls.sparkline %}<div class="kpi-spark">{{ malicious_urls.sparkline | safe }}</div>{% endif %}
    </div>
    <div class="kpi-card">
      <div class="value">
        {% if malicious_urls.trend_pct is none %}
          N/A
        {% elif malicious_urls.trend_pct >= 0 %}
          <span class="trend-up">+{{ malicious_urls.trend_pct }}%</span>
        {% else %}
          <span class="trend-down">{{ malicious_urls.trend_pct }}%</span>
        {% endif %}
      </div>
      <div class="label">Trend vs previous run</div>
    </div>
  </div>

  {% if malicious_urls.trend_chart %}
  <div class="chart-row">
    <div class="chart-card chart-card--full">
      <p class="chart-card-title">Malicious URLs online — run history</p>
      {{ malicious_urls.trend_chart | safe }}
    </div>
  </div>
  {% endif %}

  {% if malicious_urls['items'] %}
  <table>
    <thead>
      <tr>
        <th>URL</th>
        <th>Threat type</th>
        <th>Tags</th>
        <th>Added</th>
        <th>Link</th>
      </tr>
    </thead>
    <tbody>
      {% for item in malicious_urls['items'] %}
      <tr>
        <td class="mono">{{ item.url }}{% if item.sources and item.sources | length > 1 %} <span class="badge badge-neutral">VERIFIED x{{ item.sources | length }}</span>{% endif %}</td>
        <td>{{ item.threat_type if item.threat_type else "N/A" }}</td>
        <td>{{ item.tags | join(", ") if item.tags else "-" }}</td>
        <td>{{ item.date_added | fmt_date_short }}</td>
        <td>{{ source_link(item.url_full, "Open") }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% endif %}

  {% if malicious_urls.threat_type_breakdown %}
  <p class="chart-card-title" style="margin-top: 12px;">Threat type breakdown</p>
  {% if malicious_urls.threat_type_chart %}
  {{ malicious_urls.threat_type_chart | safe }}
  {% else %}
  <div class="chip-list">
    {% for item in malicious_urls.threat_type_breakdown %}<span class="chip{{ ' chip-lead' if loop.first }}">{{ item.threat_type }}<span class="chip-count">{{ item.count }}</span></span>{% endfor %}
  </div>
  {% endif %}
  {% endif %}
</section>
