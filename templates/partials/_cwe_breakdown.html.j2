<section class="section">
  <h2 class="section-title">CWE Breakdown</h2>
  {% if cwe.top_items %}
  <div>
    {% for item in cwe.top_items %}
    <div class="bar-row">
      <div class="bar-label">{{ item.cwe_id }} - {{ item.cwe_name }}</div>
      <div class="bar-track">
        <div class="bar-fill" style="width: {{ item.pct_of_total }}%"></div>
      </div>
      <div class="bar-count">{{ item.count }}</div>
    </div>
    {% endfor %}
  </div>
  {% endif %}
</section>
