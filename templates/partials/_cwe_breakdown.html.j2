<section class="section" id="sec-cwe-breakdown">
  <h2 class="section-title">CWE Breakdown</h2>
  <p class="section-desc">The underlying flaw categories (Common Weakness Enumeration) behind this week's critical CVEs — the "type of bug", not the specific product.</p>
  {% if cwe.top_items %}
  <table>
    <thead>
      <tr>
        <th>CWE</th>
        <th class="col-count">Count</th>
      </tr>
    </thead>
    <tbody>
      {% for item in cwe.top_items %}
      <tr>
        <td>{{ item.cwe_id }} - {{ item.cwe_name }}</td>
        <td class="mono col-count">{{ item.count }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% endif %}
</section>
