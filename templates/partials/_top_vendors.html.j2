<section class="section" id="sec-top-vendors">
  <h2 class="section-title">Top Vendors</h2>
  <p class="section-desc">Software vendors/products named most often across this week's critical CVEs.</p>
  {% if vendors.top_items %}
  <div class="chip-list">
    {% for item in vendors.top_items %}<span class="chip{{ ' chip-lead' if loop.first }}">{{ item.vendor_name }}<span class="chip-count">{{ item.cve_count }}</span></span>{% endfor %}
  </div>
  {% endif %}
</section>
