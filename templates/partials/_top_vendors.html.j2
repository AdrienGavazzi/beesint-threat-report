<section class="section">
  <h2 class="section-title">Top Vendors</h2>
  {% if vendors.top_items %}
  {% set max_count = vendors.top_items | map(attribute="cve_count") | list | max %}
  <div>
    {% for item in vendors.top_items %}
    <div class="bar-row">
      <div class="bar-label">{{ item.vendor_name }}</div>
      <div class="bar-track">
        <div class="bar-fill" style="width: {{ (item.cve_count / max_count * 100) if max_count else 0 }}%"></div>
      </div>
      <div class="bar-count">{{ item.cve_count }}</div>
    </div>
    {% endfor %}
  </div>
  {% endif %}
</section>
