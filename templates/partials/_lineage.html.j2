<section class="section" id="sec-lineage">
  <h2 class="section-title">Pipeline Lineage &amp; Source Attribution</h2>
  <p class="section-desc">Full traceability of this run — which pipeline execution produced this report, and which upstream feeds it pulled from. All dates UTC.</p>

  <div class="kpi-grid">
    <div class="kpi-card kpi-card--wide">
      <div class="value value--run-id">{{ lineage.run_id }}</div>
      <div class="label">Run ID</div>
    </div>
    <div class="kpi-card">
      <div class="value" style="font-size: 12px;">{{ lineage.period_start }} - {{ lineage.period_end }}</div>
      <div class="label">Period</div>
    </div>
    <div class="kpi-card">
      <div class="value" style="font-size: 12px; font-family: var(--font-mono);">{{ lineage.pipeline_duration_seconds }}s</div>
      <div class="label">Pipeline duration</div>
    </div>
  </div>

  <div class="lineage-list">
    {% for group in lineage.sources_by_category %}
    <div class="lineage-group">
      <p class="lineage-group-title">{{ group.category }}</p>
      {% for source in group.sources %}
      <div class="lineage-row">
        <span class="lineage-row-name">{{ source.name }}</span>
        <span class="lineage-row-url mono">{{ source.url }}</span>
        <span class="lineage-row-note">{{ source.note }}</span>
      </div>
      {% endfor %}
    </div>
    {% endfor %}
  </div>
</section>
