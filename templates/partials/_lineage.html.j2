<section class="section">
  <h2 class="section-title">Pipeline Lineage &amp; Source Attribution</h2>
  <p class="section-desc">Full traceability of this run — which pipeline execution produced this report, and which upstream feeds it pulled from. All dates UTC.</p>

  <div class="kpi-grid">
    <div class="kpi-card">
      <div class="value" style="font-size: 12px; font-family: var(--font-mono);">{{ lineage.run_id }}</div>
      <div class="label">Run ID</div>
    </div>
    <div class="kpi-card">
      <div class="value" style="font-size: 12px;">{{ lineage.period_start }} - {{ lineage.period_end }}</div>
      <div class="label">Period</div>
    </div>
    <div class="kpi-card">
      <div class="value" style="font-size: 12px; font-family: var(--font-mono);">{{ lineage.pipeline_duration_seconds }}s</div>
      <div class="label">Pipeline duration</div>
    </div>
  </div>

  {% set badge_colors = ["#0EA5E9", "#F59E0B", "#A78BFA", "#22C55E"] %}
  <div class="lineage-grid">
    {% for source in lineage.sources %}
    <div class="lineage-card">
      <div class="lineage-card-header">
        <span class="lineage-badge" style="background: {{ badge_colors[loop.index0 % badge_colors|length] }}22; color: {{ badge_colors[loop.index0 % badge_colors|length] }};">{{ source.name[0] }}</span>
        <p class="lineage-card-name">{{ source.name }}</p>
      </div>
      <p class="lineage-card-url mono">{{ source.url }}</p>
      <p class="lineage-card-note">{{ source.note }}</p>
    </div>
    {% endfor %}
  </div>
</section>
